# ════════════════════════════════════════════════════════
#  CONFIGURATION DE L'ORCHESTRE V2 — MULTI-API
# ════════════════════════════════════════════════════════
#  Copie ce fichier en .env puis remplis les clés.
#  Plus tu mets de clés, plus l'orchestre est résilient
#  (si une API tombe, l'autre prend le relais).
#
#  ⚠️  Ne JAMAIS mettre ce fichier sur GitHub ! (.gitignore)
# ════════════════════════════════════════════════════════

# ──── CERVEAU 1 : GROQ (priorité la plus haute) ────
# Gratuit : https://console.groq.com  (clé commence par gsk_)
GROQ_API_KEY=gsk_colle_ta_cle_ici
# GROQ_MODEL=llama-3.3-70b-versatile

# ──── CERVEAU 2 : GOOGLE GEMINI (fallback) ────
# Gratuit : https://aistudio.google.com/apikey  (clé commence par AIza)
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash

# ──── CERVEAU 3 : OPENROUTER (dernier recours) ────
# Gratuit : https://openrouter.ai/keys  (clé commence par sk-or-)
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# ──── BOT TELEGRAM (pour piloter depuis ton téléphone) ────
# 1. Parle à @BotFather sur Telegram → /newbot → reçois le token
# 2. Pour l'ID de chat : parle à @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ──── GITHUB (pour déclencher les workflows depuis le bot) ────
# Crée un token : GitHub → Settings → Developer settings → Personal access token
# (droit "repo" + "workflow")
GITHUB_TOKEN=
GITHUB_REPO=ton-nom/orchestre-ia
